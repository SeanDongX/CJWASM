// P5 标准库特性验证: now() (std.time) / println (std.log 替代)

// =============================================================
// now(): 返回纳秒级时间戳 (基于 WASI clock_time_get)
// =============================================================

func testNow(): Int64 {
    let t1 = now()
    // 时间戳应该大于 0
    if (t1 > 0) {
        return 1
    }
    return 0
}

// =============================================================
// println / print: 基本日志输出 (std.log 的简化替代)
// =============================================================

func testLog(): Int64 {
    // 直接使用 println 作为日志输出
    println("LOG: test message")
    println(42)
    return 1
}

// =============================================================
// 主函数
// =============================================================

main(): Int64 {
    let a = testNow()     // 1
    let b = testLog()     // 1

    println(a)
    println(b)

    @Assert(a, 1)
    @Assert(b, 1)

    return a + b
    // 预期输出: 2
}
